# Maintainer: pCloud <support@pcloud.com>
pkgname=pcloud-cli
pkgver=3.0.0.preview.04
pkgrel=1
pkgdesc="pCloud console client — FUSE-based virtual drive with Crypto folder support"
arch=('x86_64' 'aarch64' 'armv7h')
url="https://www.pcloud.com"
license=('BSD-3-Clause')
depends=('fuse2' 'sqlite' 'openssl' 'zlib' 'systemd-libs')
makedepends=('rust' 'cargo' 'clang' 'pkgconf' 'git')
source=("${pkgname}::git+https://github.com/pCloud/console-client.git#tag=v${pkgver//.preview/-preview}")
sha256sums=('SKIP')

prepare() {
    cd "${srcdir}/${pkgname}"
    git submodule update --init --recursive
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "${srcdir}/${pkgname}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

check() {
    cd "${srcdir}/${pkgname}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo test --frozen --release
}

package() {
    cd "${srcdir}/${pkgname}"
    install -Dm755 "target/release/pcloud" "${pkgdir}/usr/bin/pcloud"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}